<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/stat_sys_phone_call"
        android:layout_marginBottom="16dp"
        app:tint="@color/accent_pink" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fake Call Setup"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use this feature to politely escape unsafe situations."
        android:textSize="14sp"
        android:textColor="@color/text_light"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"
        android:layout_marginTop="8dp"/>

    <EditText
        android:id="@+id/etCallerName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Caller Name (e.g., Mom, Boss)"
        android:background="@drawable/card_bg_soft"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delay Before Ringing:"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerDelay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:background="@drawable/card_bg_soft"
        android:contentDescription="Select delay time"
        android:minHeight="48dp"
        android:padding="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScheduleCall"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Schedule Fake Call"
        android:textSize="18sp"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/accent_purple"/>

</LinearLayout>