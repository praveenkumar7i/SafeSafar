<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#EDE7F6"
                android:endColor="#D1C4E9"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Subtle grid line overlay (simulates map grid) -->
    <item android:top="48dp" android:bottom="48dp" android:left="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#20673AB6"/>
            <solid android:color="#00000000"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</layer-list>
